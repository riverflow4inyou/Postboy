# =========================
# Rust / Cargo
# =========================
# Compiled output (binaries, libs, incremental caches)
/target/

# Backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows debugger files
*.pdb

# Cargo.lock should be committed for application crates (do NOT ignore)

# =========================
# Tauri
# =========================
# Auto-generated schema files for capability auto-completion
/gen/schemas

# Bundle output (in case it's ever produced outside /target)
/bundle

# =========================
# Environment / Secrets
# =========================
.env
.env.*
!.env.example

# =========================
# OS / Editor
# =========================
.DS_Store
Thumbs.db
*.log
